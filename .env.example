# SPDX-License-Identifier: Apache-2.0
# Meridian — Beispiel-Umgebungskonfiguration.
# Kopieren nach Repo-Root:  cp meridian/.env.example .env
# NIEMALS echte Secrets committen — .env steht in .dockerignore + .gitignore.

# ── Kern ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3011
MERIDIAN_BASE_PATH=/opt/meridian
DB_PATH=/data/meridian.db
MODULES_ENABLED=core,devops-gate,audit-logger

# ── Generalisierung (ersetzt produkt-spezifische Hardcodes) ──────────────
MERIDIAN_SERVER_HOST=localhost
# JSON-Map repo→pfad; leer = Enricher deaktiviert sich selbst
MERIDIAN_APP_PATHS={}

# ── Git-Forge-Adapter ────────────────────────────────────────────────────
FORGEJO_BASE_URL=http://localhost:3000
CRA_DASHBOARD_BASE=http://localhost:3011/cra
# GITHUB_CRA_TOKEN=            # fine-grained PAT (Commit statuses RW, Checks RW)

# ── S3 / WORM-Audit (SeaweedFS — B-01) ────────────────────────────────────
CRA_MINIO_ENDPOINT=seaweedfs       # Service-Name im Compose-Netz
CRA_MINIO_PORT=8333                # SeaweedFS S3 (war MinIO 9000)
CRA_MINIO_ACCESS_KEY=changeme
CRA_MINIO_SECRET_KEY=changeme

# ── LLM-Router (Tier: lokal → DeepSeek → Anthropic) ──────────────────────
# Modell-IDs: Claude 4 NICHT datiert (claude-sonnet-4-6, claude-opus-4-8,
# claude-haiku-4-5-20251001). Datierte 4er-IDs → HTTP 404.
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
LLM_DAILY_CAP_USD=5

# ── Auth (OIDC Pflicht im Produkt; Stub via Feature-Flag) ────────────────
MERIDIAN_AUTH_ENABLED=false         # 1/true = Token (X-CRA-Token) erzwingen; false = offen (Dev/Healthcheck)
# Token fuer /api/cra/* wenn MERIDIAN_AUTH_ENABLED=1 (sonst nur Log-Hinweis beim Boot).
CRA_API_TOKEN=changeme
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# ── E-Mail (Notifier) ─────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── AST Engine ───────────────────────────────────────────────────────────────
# URL of the AST engine service (Gate 2). Default targets the bundled container.
# Override when running the engine on a different host or port.
MERIDIAN_AST_ENGINE_URL=http://10.89.1.42:3000

# Path to a JSON file containing custom regex-based AST rules (no code needed).
# Format: array of { id, pattern, severity, message, file_pattern?, exempt_paths?, score? }
# Leave unset to use built-in rules only.
MERIDIAN_AST_RULES_PATH=

# Directory containing custom JS rule modules (full API, same as built-ins).
# Each .js file must export: { id, severity, fn(diff, helpers) => violations[] }
# Leave unset to use built-in rules only.
MERIDIAN_AST_RULES_DIR=
